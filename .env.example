# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic (for cloze sentence generation)
ANTHROPIC_API_KEY=sk-ant-...

# PIN auth — single value used on both client and server
NEXT_PUBLIC_APP_PIN=1234

# Max words that can be added per calendar day (guards API cost abuse)
MAX_WORDS_PER_DAY=50
