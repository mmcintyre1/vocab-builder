# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-side only, bypasses RLS. Never use NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Model to use for card generation — defaults to claude-haiku-4-5-latest if unset
CLAUDE_MODEL=claude-haiku-4-5-20251001

# PIN auth — single value used on both client and server
NEXT_PUBLIC_APP_PIN=1234

# Rate limits (guards API cost abuse)
MAX_WORDS_PER_DAY=50
MAX_PREVIEWS_PER_DAY=60
