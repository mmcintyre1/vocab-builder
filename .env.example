# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic (for cloze sentence generation)
ANTHROPIC_API_KEY=sk-ant-...

# PIN auth — both vars must be set to the same value
# NEXT_PUBLIC_APP_PIN is checked client-side (PIN gate component)
# APP_PIN is checked server-side (API routes)
NEXT_PUBLIC_APP_PIN=1234
APP_PIN=1234
